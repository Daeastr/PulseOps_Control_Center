        {
          "step": 2,
          "screen": "stream_health_monitor",
          "action": "Request times out (30 seconds exceeded).",
          "expected_outcome": "Error banner: 'Failed to load stream data. Retry?' Skeleton replaced with empty state."
        },
        {
          "step": 3,
          "screen": "stream_health_monitor",
          "action": "User clicks 'Retry'. API responds within normal time.",
          "expected_outcome": "Stream list loads and renders correctly."
        }
      ]
    }
