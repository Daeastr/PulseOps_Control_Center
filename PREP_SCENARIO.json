  "scenarios": {
    "happy_path": {
      "id": "happy_path",
      "name": "Happy Path — Full Incident Lifecycle",
      "description": "User monitors streams, detects a degraded stream, raises an incident, triages it, and resolves it with approval.",
      "steps": [
        {
          "step": 1,
          "screen": "stream_health_monitor",
          "action": "User loads the dashboard. Stream list loads successfully.",
          "input": null,
          "expected_outcome": "Stream list renders with health indicators. One stream shows 'Degraded' status."
        },
        {
          "step": 2,
          "screen": "stream_detail",
          "action": "User clicks 'View stream details' on the degraded stream.",
          "input": { "stream_id": "stream-42" },
          "expected_outcome": "Detail page loads. Charts show elevated latency over the last 15 minutes."
        },
        {
          "step": 3,
          "screen": "incident_response_workflow",
          "action": "User clicks 'Raise Incident'. Fills in title, selects P2 severity, selects affected stream, adds description.",
          "input": {
            "incident_title": "Stream-42 elevated latency — possible upstream congestion",
            "severity": "P2 – High",
            "affected_streams": ["stream-42"],
            "description": "Latency spiked from 80ms to 420ms over the past 15 minutes."
          },
          "expected_outcome": "Incident created. Incident ID returned. Moved to triage step."
        },
        {
          "step": 4,
          "screen": "incident_response_workflow",
          "action": "User assigns incident to on-call engineer, adds runbook link.",
          "input": {
            "assignee": "eng-jane-doe",
            "runbook_link": "https://wiki.example.com/runbooks/stream-latency",
            "triage_notes": "Checked upstream provider. Congestion confirmed."
          },
          "expected_outcome": "Triage saved. Moved to resolve step."
        },
        {
          "step": 5,
          "screen": "incident_response_workflow",
          "action": "User submits resolution with summary and root cause.",
          "input": {
            "resolution_summary": "Upstream provider resolved congestion. Latency returned to baseline.",
            "root_cause": "Third-party Dependency",
            "follow_up_required": false
          },
          "expected_outcome": "Resolution submitted for approval. Banner: 'Resolution pending approval.'"
        },
        {
          "step": 6,
          "screen": "incident_response_workflow",
          "action": "Approver reviews and grants approval.",
          "expected_outcome": "Incident status changes to 'Resolved'. Audit log entry created."
        },
        {
          "step": 7,
          "screen": "audit_log",
          "action": "User navigates to Audit Log to verify the complete incident record.",
          "expected_outcome": "Audit log shows all events: Created, Assigned, Resolved, Approval Granted."
        }
      ]
    },

    "edge_case_path": {
      "id": "edge_case_path",
      "name": "Edge Case Path — Approval Rejected, Re-submission",
      "description": "An approver rejects the first resolution. The operator revises and resubmits.",
      "steps": [
        {
          "step": 1,
          "screen": "incident_response_workflow",
          "action": "Operator submits resolution. Approver rejects with reason: 'Root cause unclear.'",
          "expected_outcome": "Red banner: 'Approval rejected. Reason: Root cause unclear.' Resolution form re-enabled."
        },
        {
          "step": 2,
          "screen": "incident_response_workflow",
          "action": "Operator updates resolution summary and changes root cause to 'Infrastructure', resubmits.",
          "input": {
            "resolution_summary": "Identified upstream router misconfiguration. Provider corrected routing tables.",
            "root_cause": "Infrastructure",
            "follow_up_required": true
          },
          "expected_outcome": "Resolution resubmitted. Banner: 'Resolution pending approval.'"
        },
        {
          "step": 3,
          "screen": "incident_response_workflow",
          "action": "Approver reviews revised resolution and approves.",
          "expected_outcome": "Incident resolved. Audit log updated with rejection and re-approval events."
        }
      ]
    },

    "failure_path": {
      "id": "failure_path",
      "name": "Failure Path — API Failure During Incident Creation",
      "description": "The backend returns a 500 error when the user submits a new incident.",
      "steps": [
        {
          "step": 1,
          "screen": "incident_response_workflow",
          "action": "User fills in all required fields and clicks 'Create Incident'. API returns 500.",
          "expected_outcome": "Error banner: 'Failed to submit incident. Retry?' Form data preserved."
        },
        {
          "step": 2,
          "screen": "incident_response_workflow",
          "action": "User clicks 'Retry'. API returns 200 on the second attempt.",
          "expected_outcome": "Incident created successfully. Proceeds to triage step."
        }
      ]
    },

    "invalid_input_path": {
      "id": "invalid_input_path",
      "name": "Invalid Input Path — Required Fields Missing",
      "description": "User attempts to submit an incident without filling required fields.",
      "steps": [
        {
          "step": 1,
          "screen": "incident_response_workflow",
          "action": "User leaves 'Incident Title' and 'Affected Streams' blank and clicks 'Create Incident'.",
          "expected_outcome": "Client-side validation fires. Inline errors: 'Title is required.' and 'At least one stream must be selected.' Form not submitted."
        },
        {
          "step": 2,
          "screen": "incident_response_workflow",
          "action": "User enters a title exceeding 200 characters.",
          "expected_outcome": "Inline error: 'Title must be 200 characters or fewer.' Character count shown."
        },
        {
          "step": 3,
          "screen": "incident_response_workflow",
          "action": "User enters an invalid URL in the Runbook URL field.",
          "expected_outcome": "Inline error: 'Please enter a valid URL.' Form not submitted until corrected."
        }
      ]
    },

    "timeout_slow_response_path": {
      "id": "timeout_slow_response_path",
      "name": "Timeout / Slow Response Path — Stream Data Delayed",
      "description": "The stream health API is slow or times out.",
      "steps": [
        {
          "step": 1,
          "screen": "stream_health_monitor",
          "action": "User loads the dashboard. API call to /api/streams takes more than 10 seconds.",
