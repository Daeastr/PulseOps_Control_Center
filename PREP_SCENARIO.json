  "validation_rules": {
    "incident_title": { "required": true, "max_length": 200 },
    "incident_description": { "required": false, "max_length": 2000 },
    "resolution_summary": { "required": true, "max_length": 2000 },
    "runbook_link": { "required": false, "format": "url" },
    "affected_streams": { "required": true, "min_items": 1 }
  },

  "governance": {
    "policy_engine": "metadata-policy",
    "human_approval_required_for": ["Resolve Incident"],
    "runtime_drift_detection": true
  },

  "environments": [
    { "name": "local", "auto_deploy": false, "approval_required": false },
    { "name": "preview", "auto_deploy": true, "approval_required": false },
    { "name": "prod", "auto_deploy": false, "approval_required": true }
  ]
